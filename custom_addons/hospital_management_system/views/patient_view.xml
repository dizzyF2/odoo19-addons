<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- *****************************  form ***************************** -->
    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet string="Patient">
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="phone"/>
                    </group>
                </sheet>

            </form>
        </field>
    </record>
    
    <!-- in odoo version 17+ i think they replace tree view with list from <tree> to <list> and sp on -->
    <!-- *****************************  list ***************************** -->
    <record id="view_hospital_patient_list" model="ir.ui.view">
        <field name="name">patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <!-- *****************************  action ***************************** -->
     <record id="action_patient_views" model="ir.actions.act_window">
        <field name="name">Cleopatra Patient</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="a_view_nocontent_smiling_face">
                create your first patient!
            </p>
        </field>
     </record>

     <!-- *****************************  menu ***************************** -->
    <menuitem
        id="menu_hospital_root"
        name="Cleopatra"
    />

     <menuitem
        id="menu_patient_views"
        name="Patient"
        action="action_patient_views"
        parent="menu_hospital_root"
    />
</odoo>