<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_student_by_teacher" model="ir.rule">
        <field name="name">Student Belong to what Teacher</field>
        <field name="model_id" ref="school_management_system.model_school_student" />
        <field name="domain_force">[('teacher_id','=',user.id)]</field>
        <field name="groups" eval="[(4,ref('group_teacher'))]" />
    </record>

    <record id="rule_enrollments_teacher" model="ir.rule">
        <field name="name">Teacher see its own student's enrollments</field>
        <field name="model_id" ref="school_management_system.model_school_enrollment" />
        <field name="domain_force">[('student_id.teacher_id','=',user.id)]</field>
        <field name="groups" eval="[(4,ref('group_teacher'))]" />
    </record>

</odoo>
