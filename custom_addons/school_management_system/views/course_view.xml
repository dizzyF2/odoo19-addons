<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="course_list_view" model="ir.ui.view">
        <field name="name">school_course.view.list</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <list string="List Title">
                <field name="name" />
                <field name="description" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="course_form_view" model="ir.ui.view">
        <field name="name">school_course.view.form</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Course Information">
                        <field name="name" />
                        <field name="description" />
                    </group>
                    <group string="Course Status">
                        <field name="active" />
                    </group>
                    <notebook>
                        <page name="enrollments" string="Enrolled Students">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="student_id" />
                                    <field name="enrollment_date" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="course_action" model="ir.actions.act_window">
        <field name="name">Course Action</field>
        <field name="res_model">school.course</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>
                Add your first Course!
            </p>
        </field>
    </record>

    <menuitem
        id="course_action_menu"
        name="Course Management"
        action="course_action"
        parent="school_course_sub_menu"
        sequence="1"
        />
</odoo>
