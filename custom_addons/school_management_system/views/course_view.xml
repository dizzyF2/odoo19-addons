<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="course_list_view" model="ir.ui.view">
        <field name="name">school_course.view.list</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <list string="List Title">
                <field name="name" />
                <field name="description" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="course_form_view" model="ir.ui.view">
        <field name="name">school_course.view.form</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <form>
                <field name="state" widget="statusbar" class="d-flex" />
                <sheet>
                    <header>
                        <button type="object" name="action_schechuled" string="Schedule" class="btn btn-primary" invisible="state !='draft' " />
                        <button type="object" name="action_start" string="Start" class="btn btn-secondary" invisible="state !='scheduled' " />
                        <button type="object" name="action_done" string="Completed" class="btn btn-success" invisible="state != 'start' " />
                        <button type="object" name="action_cancel" string="Cancel" class="btn btn-danger" invisible="state == 'done' or state == 'cancelled' " />
                    </header>
                    <group string="Course Information">
                        <field name="name" readonly="state == 'done'"/>
                        <field name="description" readonly="state == 'done'"/>
                    </group>
                    <group string="Course Status">
                        <field name="active" readonly="state == 'done'" />
                    </group>
                    <notebook>
                        <page name="enrollments" string="Enrolled Students">
                            <field name="enrollment_ids" readonly="state == 'done'">
                                <list>
                                    <field name="student_id" readonly="parent.state == 'done'"/>
                                    <field name="enrollment_date" readonly="parent.state == 'done'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="course_action" model="ir.actions.act_window">
        <field name="name">Course Action</field>
        <field name="res_model">school.course</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>
                Add your first Course!
            </p>
        </field>
    </record>

    <menuitem
        id="course_action_menu"
        name="Course Management"
        action="course_action"
        parent="school_course_sub_menu"
        sequence="1"
        />
</odoo>
