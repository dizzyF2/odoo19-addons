<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="enrollment_list_view" model="ir.ui.view">
        <field name="name">school_enrollment.view.list</field>
        <field name="model">school.enrollment</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id" />
                <field name="course_id" />
                <field name="grade" />
                <field name="enrollment_date" />
            </list>
        </field>
    </record>

    <record id="model_name_view_form" model="ir.ui.view">
        <field name="name">school_enrollment.view.form</field>
        <field name="model">school.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Student Information">
                        <field name="student_id" />
                    </group>
                    <group string="Enrollment Information">
                        <field name="course_id" />
                        <field name="grade" />
                        <field name="enrollment_date" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="school_enrollment_view_kanban" model="ir.ui.view">
        <field name="name">school_enrollment.view.kanban</field>
        <field name="model">school.enrollment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="course_id">
                <templates>
                    <t t-name="card">
                        <card class="oe_kanban_global_box">
                                <h3 class="h3 text-muted">
                                    <field name="student_id" />
                                </h3>
                                <h4 class="h4">
                                    <field name="grade"/>
                                </h4>
                        </card>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="enrollment_action" model="ir.actions.act_window">
        <field name="name">Enrollment Action</field>
        <field name="res_model">school.enrollment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p>
                Start Enroll
            </p>
        </field>
    </record>

    <menuitem
        id="enrollment_action_menu"
        name="Enrollment Management"
        action="enrollment_action"
        parent="school_enrollment_sub_menu"
        />

</odoo>
